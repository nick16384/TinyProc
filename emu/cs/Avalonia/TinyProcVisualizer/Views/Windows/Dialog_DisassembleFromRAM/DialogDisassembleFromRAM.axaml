<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TinyProcVisualizer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="TinyProcVisualizer.Views.Windows.Dialog_DisassembleFromRAM.DialogDisassembleFromRAM"
        x:DataType="vm:Dialog_DisassembleFromRAM.DialogDisassembleFromRAM_ViewModel"
        WindowStartupLocation="CenterOwner"
        Width="300" Height="190"
        Icon="/Assets/avalonia-logo.ico"
        Title="Disassemble from RAM">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Name="Grid_DisassemblingAddressRanges" ColumnDefinitions="220, 50" RowDefinitions="0.7*, 0.9*, 0.7*, 0.9*, 1.3*" Margin="5">
        <Label Grid.Row="0" Grid.Column="0">Decompilation start address:</Label>
        <TextBox Grid.Row="1" Grid.Column="0" Name="TextBox_DisassemblingStartAddress" HorizontalAlignment="Stretch" />
        <Button Grid.Row="1" Grid.Column="1" Click="Button_SetMinStartAddress_OnClick" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            Min
        </Button>

        <Label Grid.Row="2" Grid.Column="0">Decompilation end address:</Label>
        <TextBox Grid.Row="3" Grid.Column="0" Name="TextBox_DisassemblingEndAddress" HorizontalAlignment="Stretch" />
        <Button Grid.Row="3" Grid.Column="1" Click="Button_SetMaxEndAddress_OnClick" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            Max
        </Button>

        <Button Grid.Row="4" Grid.Column="0" Click="Button_SubmitAddressRanges_OnClick" Width="90" VerticalAlignment="Stretch" Margin="0, 20, 0, 3">
            Decompile
        </Button>
    </Grid>

</Window>